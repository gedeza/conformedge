  @@map("approval_workflow_templates")
}

model ApprovalRequest {
  id             String                @id @default(uuid())
  status         ApprovalRequestStatus @default(IN_PROGRESS)
  documentId     String                @map("document_id")
  templateId     String?               @map("template_id")
