  assignedTo      User            @relation("ApprovalStepAssignee", fields: [assignedToId], references: [id])

  @@index([approvalRequestId, stepOrder], map: "idx_approval_step_request_order")
  @@index([assignedToId, status], map: "idx_approval_step_assignee_status")
  @@map("approval_steps")
}

