  @@index([organizationId, createdAt(sort: Desc)], map: "idx_credit_tx_org_created")
  @@index([type], map: "idx_credit_tx_type")
  @@map("credit_transactions")
}

model UsageRecord {
  id                      String   @id @default(uuid())
  periodStart             DateTime @map("period_start")
  periodEnd               DateTime @map("period_end")
  aiClassificationsUsed   Int      @default(0) @map("ai_classifications_used")
  documentsCount          Int      @default(0) @map("documents_count")
  usersCount              Int      @default(0) @map("users_count")
