  recordedBy User      @relation("MeasurementRecorder", fields: [recordedById], references: [id])

  @@index([objectiveId, measuredAt(sort: Desc)], map: "idx_measurement_obj_date")
  @@map("objective_measurements")
}

// ─────────────────────────────────────────────
// MANAGEMENT REVIEWS
// ─────────────────────────────────────────────

model ManagementReview {
  id             String                     @id @default(uuid())
  title          String
  reviewDate     DateTime                   @map("review_date")
  location       String?
  status         ManagementReviewStatus     @default(PLANNED)
  meetingMinutes String?                    @map("meeting_minutes")
  nextReviewDate DateTime?                  @map("next_review_date")
  organizationId String                     @map("organization_id")
  facilitatorId  String                     @map("facilitator_id")
  createdById    String                     @map("created_by_id")
  createdAt      DateTime                   @default(now()) @map("created_at")
  updatedAt      DateTime                   @updatedAt @map("updated_at")

  organization Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  facilitator  User                        @relation("ReviewFacilitator", fields: [facilitatorId], references: [id])
  createdBy    User                        @relation("ReviewCreator", fields: [createdById], references: [id])
  standards    ManagementReviewStandard[]
  attendees    ManagementReviewAttendee[]
  agendaItems  ManagementReviewAgendaItem[]
  actions      ManagementReviewAction[]

  @@index([organizationId, reviewDate(sort: Desc)], map: "idx_mgmt_review_org_date")
  @@index([organizationId, status], map: "idx_mgmt_review_org_status")
  @@map("management_reviews")
}

model ManagementReviewStandard {
  id         String   @id @default(uuid())
  reviewId   String   @map("review_id")
  standardId String   @map("standard_id")
  createdAt  DateTime @default(now()) @map("created_at")

  review   ManagementReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  standard Standard         @relation(fields: [standardId], references: [id])

  @@unique([reviewId, standardId])
  @@map("management_review_standards")
}

model ManagementReviewAttendee {
  id        String   @id @default(uuid())
  reviewId  String   @map("review_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  review ManagementReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User             @relation(fields: [userId], references: [id])

  @@unique([reviewId, userId])
  @@map("management_review_attendees")
}

model ManagementReviewAgendaItem {
  id        String         @id @default(uuid())
  reviewId  String         @map("review_id")
  type      AgendaItemType
  title     String
  notes     String?
  sortOrder Int            @map("sort_order")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  review ManagementReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("management_review_agenda_items")
}

model ManagementReviewAction {
  id          String             @id @default(uuid())
  reviewId    String             @map("review_id")
  description String
  status      ReviewActionStatus @default(OPEN)
  dueDate     DateTime?          @map("due_date")
  completedAt DateTime?          @map("completed_at")
  assigneeId  String?            @map("assignee_id")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  review   ManagementReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  assignee User?            @relation(fields: [assigneeId], references: [id])

  @@index([reviewId, status], map: "idx_review_action_status")
  @@map("management_review_actions")
}

// ─────────────────────────────────────────────
// PARTNER PROGRAM
// ─────────────────────────────────────────────

model Partner {
  id                  String        @id @default(uuid())
  name                String                             // Partner company name
  slug                String        @unique              // URL-safe identifier
  tier                PartnerTier
  status              PartnerStatus @default(APPLIED)
  contactEmail        String        @map("contact_email")
  contactPhone        String?       @map("contact_phone")
  website             String?
  registrationNumber  String?       @map("registration_number") // SA CIPC number
  description         String?       @db.Text

  // Pricing (negotiable per partner — these are defaults for new client orgs)
  basePlatformFeeCents    Int       @map("base_platform_fee_cents")   // Monthly platform fee in cents
  defaultSmallFeeCents    Int       @default(129900) @map("default_small_fee_cents")   // R1,299 default
  defaultMediumFeeCents   Int       @default(189900) @map("default_medium_fee_cents")  // R1,899 default
  defaultLargeFeeCents    Int       @default(249900) @map("default_large_fee_cents")   // R2,499 default
  volumeDiscountPercent   Float     @default(0) @map("volume_discount_percent")        // Negotiated volume discount
  commissionPercent       Float     @default(15) @map("commission_percent")            // Referral commission %

  // Branding (WHITE_LABEL partners)
  logoKey             String?   @map("logo_key")              // R2 key for partner logo
  primaryColor        String?   @map("primary_color")         // Hex color e.g. #1e40af
  accentColor         String?   @map("accent_color")          // Hex color e.g. #3b82f6
  brandName           String?   @map("brand_name")            // Display name override

  // Operational
  maxClientOrgs       Int?          @map("max_client_orgs")          // null = unlimited
  approvedAt          DateTime?     @map("approved_at")
  terminatedAt        DateTime?     @map("terminated_at")
  notes               String?       @db.Text                         // Internal admin notes
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  // Relations
  partnerUsers        PartnerUser[]
  clientOrganizations PartnerOrganization[]
  invoices            PartnerInvoice[]
  referrals           Referral[]

  @@index([status], map: "idx_partner_status")
  @@index([tier], map: "idx_partner_tier")
  @@map("partners")
}

model PartnerUser {
  id          String      @id @default(uuid())
  partnerId   String      @map("partner_id")
  userId      String      @map("user_id")
  role        PartnerRole @default(PARTNER_MANAGER)
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([partnerId, userId])
  @@index([userId], map: "idx_partner_user_user")
  @@map("partner_users")
}

model PartnerOrganization {
  id                String           @id @default(uuid())
  partnerId         String           @map("partner_id")
  organizationId    String           @map("organization_id")
  clientSize        PartnerClientSize @default(SMALL) @map("client_size")
  isActive          Boolean          @default(true) @map("is_active")

  // Per-client fee override (null = use partner default for this size)
  customFeeCents    Int?             @map("custom_fee_cents")

  // Metadata
  onboardedAt       DateTime         @default(now()) @map("onboarded_at")
  disconnectedAt    DateTime?        @map("disconnected_at")
  notes             String?          @db.Text
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  partner      Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([partnerId, organizationId])
  @@index([organizationId], map: "idx_partner_org_org")
  @@map("partner_organizations")
}

model PartnerInvoice {
  id                  String        @id @default(uuid())
  partnerId           String        @map("partner_id")
  invoiceNumber       String        @unique @map("invoice_number")
  status              InvoiceStatus @default(DRAFT)

  // Amounts in cents (ZAR)
  platformFeeCents    Int           @map("platform_fee_cents")
  clientFeesCents     Int           @map("client_fees_cents")     // Sum of all per-client fees
  discountCents       Int           @default(0) @map("discount_cents") // Volume discount
  subtotalCents       Int           @map("subtotal_cents")
  vatCents            Int           @map("vat_cents")             // 15% SA VAT
  totalCents          Int           @map("total_cents")

  // Period
  periodStart         DateTime      @map("period_start")
  periodEnd           DateTime      @map("period_end")
  dueAt               DateTime      @map("due_at")
  paidAt              DateTime?     @map("paid_at")

  // Line items breakdown (JSON array)
  lineItems           Json          @map("line_items")

  // Payment
  externalPaymentId   String?       @map("external_payment_id")
  notes               String?       @db.Text

  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, createdAt(sort: Desc)], map: "idx_partner_invoice_partner")
  @@index([status], map: "idx_partner_invoice_status")
  @@map("partner_invoices")
}

// ─────────────────────────────────────────────
// REFERRAL PROGRAM
// ─────────────────────────────────────────────

enum ReferralStatus {
  PENDING       // Link generated, no signup yet
  CLICKED       // Link was visited
  SIGNED_UP     // Org created but not paid
  CONVERTED     // Org became a paid customer
  EXPIRED       // Link expired without conversion
  CANCELLED     // Manually cancelled
}

model Referral {
  id                String         @id @default(uuid())
  partnerId         String         @map("partner_id")
  code              String         @unique                    // e.g. "acme-x7k2m9"

  // Tracking
  referredOrgId     String?        @map("referred_org_id")
  status            ReferralStatus @default(PENDING)

  // Contact info captured at signup
  referredEmail     String?        @map("referred_email")
  referredCompany   String?        @map("referred_company")

  // Conversion tracking
  clickCount        Int            @default(0) @map("click_count")
  signedUpAt        DateTime?      @map("signed_up_at")
  convertedAt       DateTime?      @map("converted_at")

  // Commission
  commissionPercent Float          @map("commission_percent")  // Snapshot from partner at creation
  commissionCents   Int?           @map("commission_cents")    // Calculated on conversion
  commissionPaidAt  DateTime?      @map("commission_paid_at")

  expiresAt         DateTime       @map("expires_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  partner      Partner       @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  referredOrg  Organization? @relation(fields: [referredOrgId], references: [id], onDelete: SetNull)

  @@index([partnerId, status], map: "idx_referral_partner_status")
  @@map("referrals")
}

// ─────────────────────────────────────────────
// LEGAL — TERMS & AGREEMENTS
// ─────────────────────────────────────────────

model TermsVersion {
  id          String             @id @default(uuid())
  version     String             @unique              // e.g. "1.0", "1.1", "2.0"
  title       String                                  // e.g. "Terms of Service & Privacy Policy"
  content     String             @db.Text             // Full legal text (markdown)
  summary     String?            @db.Text             // Change summary for re-acceptance
  status      TermsVersionStatus @default(DRAFT)
  effectiveAt DateTime           @map("effective_at")
  publishedAt DateTime?          @map("published_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  acceptances TermsAcceptance[]

  @@index([status], map: "idx_terms_version_status")
  @@map("terms_versions")
}

model TermsAcceptance {
  id         String   @id @default(uuid())
  versionId  String   @map("version_id")
  userId     String   @map("user_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent") @db.Text
  acceptedAt DateTime @default(now()) @map("accepted_at")

  version TermsVersion @relation(fields: [versionId], references: [id])
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, versionId])
  @@index([userId, acceptedAt(sort: Desc)], map: "idx_terms_acceptance_user")
  @@index([versionId], map: "idx_terms_acceptance_version")
  @@map("terms_acceptances")
}
