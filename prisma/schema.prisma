// ─────────────────────────────────────────────
// TEAM INVITATIONS
// ─────────────────────────────────────────────


// ─────────────────────────────────────────────
// INCIDENT & NEAR-MISS MANAGEMENT
// ─────────────────────────────────────────────

model Incident {
  id               String         @id @default(uuid())
  title            String
  description      String?
  incidentType     IncidentType   @map("incident_type")
  status           IncidentStatus @default(REPORTED) @map("status")
  severity         RiskLevel      @default(MEDIUM)
  incidentDate     DateTime       @map("incident_date")
  incidentTime     String?        @map("incident_time") // HH:mm format
  location         String?
  injuredParty     String?        @map("injured_party")
  witnesses        String?        // Legacy free-text field (kept for backward compat)
  immediateAction  String?        @map("immediate_action")
  rootCause        String?        @map("root_cause")
  rootCauseData    Json?          @map("root_cause_data")
  investigationDue DateTime?      @map("investigation_due")
  closedDate       DateTime?      @map("closed_date")

  // Personnel involved (victim details)
  victimOccupation      String?    @map("victim_occupation")
  victimStaffNo         String?    @map("victim_staff_no")
  victimDepartment      String?    @map("victim_department")
  victimIdNumber        String?    @map("victim_id_number")
  victimNationality     String?    @map("victim_nationality")
  victimContractor      String?    @map("victim_contractor")
  immediateSupervisor   String?    @map("immediate_supervisor")

  // Medical treatment
  victimDateOfBirth     DateTime?  @map("victim_date_of_birth")
  treatingDoctor        String?    @map("treating_doctor")
  hospitalClinic        String?    @map("hospital_clinic")

  // COIDA / Safety fields
  lostDays            Int?       @map("lost_days")
  bodyPartInjured     String?    @map("body_part_injured")
  natureOfInjury      String?    @map("nature_of_injury")
  treatmentType       String?    @map("treatment_type") // NONE, FIRST_AID, MEDICAL, HOSPITALIZED
  contributingFactors Json?      @map("contributing_factors") // string[]
  isReportable        Boolean    @default(false) @map("is_reportable")
  reportingDeadline   DateTime?  @map("reporting_deadline")
  statutoryReportedAt DateTime?  @map("statutory_reported_at")
  statutoryRefNumber  String?    @map("statutory_ref_number")
  mhsaSection         String?    @map("mhsa_section") // "11", "23", "24"

  // Consequence & Impact
  estimatedCost       Decimal?   @map("estimated_cost") @db.Decimal(12, 2)
  spillVolume         Decimal?   @map("spill_volume") @db.Decimal(10, 2)
  impactAreas         Json?      @map("impact_areas") // ["Health", "Safety", "Environment", "Production"]
  nonInjuriousType    String?    @map("non_injurious_type") // Fire/Explosion, Equipment Damage, etc.

  // Investigation sign-off
  investigationSignedOffById String?    @map("investigation_signed_off_by_id")
  investigationSignedOffAt   DateTime?  @map("investigation_signed_off_at")
  investigationSignOffNotes  String?    @map("investigation_sign_off_notes") @db.Text

  // Outcome
  returnedToWork      Boolean?   @map("returned_to_work")
  returnedToWorkDate  DateTime?  @map("returned_to_work_date")

  organizationId   String         @map("organization_id")
  projectId        String?        @map("project_id")
  siteId           String?        @map("site_id")
  reportedById     String         @map("reported_by_id")
  investigatorId   String?        @map("investigator_id")
  capaId           String?        @map("capa_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  site         Site?        @relation(fields: [siteId], references: [id], onDelete: SetNull)
  reportedBy   User         @relation("IncidentReporter", fields: [reportedById], references: [id])
  investigator User?        @relation("IncidentInvestigator", fields: [investigatorId], references: [id])
  capa         Capa?        @relation(fields: [capaId], references: [id], onDelete: SetNull)
  investigationSignedOffBy User? @relation("IncidentSignOff", fields: [investigationSignedOffById], references: [id])
  evidence       IncidentEvidence[]
  witnessRecords IncidentWitness[]
  incidentCapas  IncidentCapa[]

  @@index([organizationId, createdAt(sort: Desc)], map: "idx_incident_org_created")
  @@index([organizationId, status], map: "idx_incident_org_status")
  @@index([organizationId, incidentType], map: "idx_incident_org_type")
  @@index([organizationId, incidentDate(sort: Desc)], map: "idx_incident_org_date")
  @@index([projectId], map: "idx_incident_project")
  @@map("incidents")
}

model IncidentEvidence {
  id           String   @id @default(uuid())
  incidentId   String   @map("incident_id")
  fileKey      String   @map("file_key")
  fileName     String   @map("file_name")
  fileType     String   @map("file_type")
  fileSize     Int      @map("file_size")
  caption      String?
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation("EvidenceUploader", fields: [uploadedById], references: [id])

  @@index([incidentId], map: "idx_incident_evidence_incident")
  @@map("incident_evidence")
}

model IncidentWitness {
  id            String   @id @default(uuid())
  incidentId    String   @map("incident_id")
  name          String
  contactNumber String?  @map("contact_number")
  email         String?
  statement     String?
  createdAt     DateTime @default(now()) @map("created_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId], map: "idx_incident_witness_incident")
  @@map("incident_witnesses")
}

model IncidentCapa {
  id         String   @id @default(uuid())
  incidentId String   @map("incident_id")
  capaId     String   @map("capa_id")
  createdAt  DateTime @default(now()) @map("created_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  capa     Capa     @relation(fields: [capaId], references: [id], onDelete: Cascade)

  @@unique([incidentId, capaId])
  @@map("incident_capas")
}

// ─────────────────────────────────────────────
// WORK PERMITS (PERMIT TO WORK)
// ─────────────────────────────────────────────

model WorkPermit {
  id                  String           @id @default(uuid())
  permitNumber        String?          @unique @map("permit_number")
  permitType          WorkPermitType   @map("permit_type")
  status              WorkPermitStatus @default(DRAFT)
  riskLevel           RiskLevel        @default(MEDIUM) @map("risk_level")
  title               String
  location            String
  description         String           @db.Text
  hazardsIdentified   String?          @db.Text @map("hazards_identified")
  precautions         String?          @db.Text
  ppeRequirements     String?          @db.Text @map("ppe_requirements")
  emergencyProcedures String?          @db.Text @map("emergency_procedures")
  validFrom           DateTime         @map("valid_from")
  validTo             DateTime         @map("valid_to")
  approvedAt          DateTime?        @map("approved_at")
  activatedAt         DateTime?        @map("activated_at")
  closedAt            DateTime?        @map("closed_at")
  closureNotes        String?          @map("closure_notes")
  organizationId      String           @map("organization_id")
  projectId           String?          @map("project_id")
  siteId              String?          @map("site_id")
  requestedById       String           @map("requested_by_id")
  issuedById          String?          @map("issued_by_id")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  site           Site?                 @relation(fields: [siteId], references: [id], onDelete: SetNull)
  requestedBy    User                  @relation("PermitRequester", fields: [requestedById], references: [id])
  issuedBy       User?                 @relation("PermitIssuer", fields: [issuedById], references: [id])
  checklistItems WorkPermitChecklist[]
  extensions     WorkPermitExtension[]

  @@index([organizationId, createdAt(sort: Desc)], map: "idx_permit_org_created")
  @@index([organizationId, status], map: "idx_permit_org_status")
  @@index([organizationId, permitType], map: "idx_permit_org_type")
  @@index([organizationId, validTo], map: "idx_permit_org_valid_to")
  @@index([projectId], map: "idx_permit_project")
  @@map("work_permits")
}

model WorkPermitChecklist {
  id          String    @id @default(uuid())
  description String
  isChecked   Boolean   @default(false) @map("is_checked")
  sortOrder   Int       @map("sort_order")
  permitId    String    @map("permit_id")
  checkedById String?   @map("checked_by_id")
  checkedAt   DateTime? @map("checked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  permit    WorkPermit @relation(fields: [permitId], references: [id], onDelete: Cascade)
  checkedBy User?      @relation("PermitChecklistChecker", fields: [checkedById], references: [id])

  @@index([permitId, sortOrder], map: "idx_permit_checklist_order")
  @@map("work_permit_checklists")
}

model WorkPermitExtension {
  id              String          @id @default(uuid())
  permitId        String          @map("permit_id")
  originalValidTo DateTime        @map("original_valid_to")
  newValidTo      DateTime        @map("new_valid_to")
  reason          String          @db.Text
  status          ExtensionStatus @default(PENDING)
  reviewedById    String?         @map("reviewed_by_id")
  reviewedAt      DateTime?       @map("reviewed_at")
  reviewNotes     String?         @map("review_notes")
  requestedById   String          @map("requested_by_id")
  createdAt       DateTime        @default(now()) @map("created_at")

  permit      WorkPermit @relation(fields: [permitId], references: [id], onDelete: Cascade)
  reviewedBy  User?      @relation("ExtensionReviewer", fields: [reviewedById], references: [id])
  requestedBy User       @relation("ExtensionRequester", fields: [requestedById], references: [id])

  @@index([permitId, createdAt(sort: Desc)], map: "idx_permit_extension_permit")
  @@index([status], map: "idx_permit_extension_status")
  @@map("work_permit_extensions")
}

// ─────────────────────────────────────────────
// BILLING & SUBSCRIPTIONS
// ─────────────────────────────────────────────

model Subscription {
  id                  String             @id @default(uuid())
  plan                PlanTier           @default(STARTER)
  status              SubscriptionStatus @default(TRIALING)
  billingCycle        BillingCycle       @default(MONTHLY) @map("billing_cycle")
  currentPeriodStart  DateTime           @map("current_period_start")
  currentPeriodEnd    DateTime           @map("current_period_end")
  trialEndsAt         DateTime?          @map("trial_ends_at")
  cancelAtPeriodEnd   Boolean            @default(false) @map("cancel_at_period_end")
  gracePeriodEndsAt   DateTime?          @map("grace_period_ends_at")
  externalSubId       String?            @map("external_sub_id")
  paymentMethod       PaymentMethod      @default(PAYSTACK) @map("payment_method")
  paymentTermsDays    Int?               @map("payment_terms_days") // null=immediate, 30, 60
  organizationId      String             @unique @map("organization_id")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status], map: "idx_subscription_status")
  @@index([trialEndsAt], map: "idx_subscription_trial_ends")
  @@index([paymentMethod], map: "idx_subscription_payment_method")
  @@map("subscriptions")
}

model Invoice {
  id                String        @id @default(uuid())
  amountCents       Int           @map("amount_cents")
  vatCents          Int           @map("vat_cents")
  totalCents        Int           @map("total_cents")
  status            InvoiceStatus @default(DRAFT)
  billingCycle      BillingCycle  @map("billing_cycle")
  periodStart       DateTime      @map("period_start")
  periodEnd         DateTime      @map("period_end")
  dueAt             DateTime      @map("due_at")
  paidAt            DateTime?     @map("paid_at")
  lineItems         Json          @map("line_items")
  externalPaymentId String?       @map("external_payment_id")
  bankReference     String?       @map("bank_reference") // EFT reference number
  organizationId    String        @map("organization_id")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // Relations
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creditTransactions  CreditTransaction[]
  accountTransactions AccountTransaction[]

  @@index([organizationId, createdAt(sort: Desc)], map: "idx_invoice_org_created")
  @@index([status], map: "idx_invoice_status")
  @@map("invoices")
}

model CreditBalance {
  id             String   @id @default(uuid())
  balance        Int      @default(0)
  lifetimeEarned Int      @default(0) @map("lifetime_earned")
  lifetimeUsed   Int      @default(0) @map("lifetime_used")
  organizationId String   @unique @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("credit_balances")
}

model CreditTransaction {
  id             String                @id @default(uuid())
  type           CreditTransactionType
  amount         Int                   // Positive = credit added, negative = credit used
  balanceAfter   Int                   @map("balance_after")
  description    String
  documentId     String?               @map("document_id")
  invoiceId      String?               @map("invoice_id")
  performedById  String?               @map("performed_by_id")
  organizationId String                @map("organization_id")
  createdAt      DateTime              @default(now()) @map("created_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt(sort: Desc)], map: "idx_credit_tx_org_created")
  @@index([type], map: "idx_credit_tx_type")
  @@map("credit_transactions")
}

model UsageRecord {
  id                      String   @id @default(uuid())
  periodStart             DateTime @map("period_start")
  periodEnd               DateTime @map("period_end")
  aiClassificationsUsed   Int      @default(0) @map("ai_classifications_used")
  documentsCount          Int      @default(0) @map("documents_count")
  usersCount              Int      @default(0) @map("users_count")
  standardsCount          Int      @default(0) @map("standards_count")
  organizationId          String   @map("organization_id")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, periodStart])
  @@index([organizationId, periodStart(sort: Desc)], map: "idx_usage_record_org_period")
  @@map("usage_records")
}

model AccountBalance {
  id                    String   @id @default(uuid())
  balanceCents          Int      @default(0) @map("balance_cents")
  lifetimeFundedCents   Int      @default(0) @map("lifetime_funded_cents")
  lifetimeDeductedCents Int      @default(0) @map("lifetime_deducted_cents")
  organizationId        String   @unique @map("organization_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions AccountTransaction[]

  @@map("account_balances")
}

model AccountTransaction {
  id                String                 @id @default(uuid())
  type              AccountTransactionType
  amountCents       Int                    @map("amount_cents") // positive=fund, negative=deduct
  balanceAfterCents Int                    @map("balance_after_cents")
  description       String
  invoiceId         String?                @map("invoice_id")
  performedById     String?                @map("performed_by_id")
  organizationId    String                 @map("organization_id")
  createdAt         DateTime               @default(now()) @map("created_at")

  // Relations
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice        Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  accountBalance AccountBalance? @relation(fields: [organizationId], references: [organizationId], map: "account_tx_balance_fkey")

  @@index([organizationId, createdAt(sort: Desc)], map: "idx_account_tx_org_created")
  @@map("account_transactions")
}

// ─────────────────────────────────────────────
// OBJECTIVES & KPI TRACKING
// ─────────────────────────────────────────────

model Objective {
  id                   String               @id @default(uuid())
  title                String
  description          String?
  status               ObjectiveStatus      @default(DRAFT)
  targetValue          Float                @map("target_value")
  currentValue         Float                @default(0) @map("current_value")
  unit                 String?
  measurementFrequency MeasurementFrequency @map("measurement_frequency")
  dueDate              DateTime?            @map("due_date")
  organizationId       String               @map("organization_id")
  standardId           String?              @map("standard_id")
  standardClauseId     String?              @map("standard_clause_id")
  ownerId              String               @map("owner_id")
  monitoringPointId    String?              @map("monitoring_point_id")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  standard        Standard?             @relation(fields: [standardId], references: [id], onDelete: SetNull)
  standardClause  StandardClause?       @relation(fields: [standardClauseId], references: [id], onDelete: SetNull)
  owner           User                  @relation("ObjectiveOwner", fields: [ownerId], references: [id])
  monitoringPoint MonitoringPoint?      @relation("MonitoringPointObjectives", fields: [monitoringPointId], references: [id], onDelete: SetNull)
  measurements    ObjectiveMeasurement[]

  @@index([organizationId, createdAt(sort: Desc)], map: "idx_objective_org_created")
  @@index([organizationId, status], map: "idx_objective_org_status")
  @@index([standardClauseId], map: "idx_objective_clause")
  @@map("objectives")
}

model ObjectiveMeasurement {
  id           String   @id @default(uuid())
  value        Float
  notes        String?
  objectiveId  String   @map("objective_id")
  recordedById String   @map("recorded_by_id")
  measuredAt   DateTime @default(now()) @map("measured_at")
  createdAt    DateTime @default(now()) @map("created_at")

  objective  Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  recordedBy User      @relation("MeasurementRecorder", fields: [recordedById], references: [id])

  @@index([objectiveId, measuredAt(sort: Desc)], map: "idx_measurement_obj_date")
  @@map("objective_measurements")
}

// ─────────────────────────────────────────────
// MANAGEMENT REVIEWS
// ─────────────────────────────────────────────

model ManagementReview {
  id             String                     @id @default(uuid())
  title          String
  reviewDate     DateTime                   @map("review_date")
  location       String?
  status         ManagementReviewStatus     @default(PLANNED)
  meetingMinutes String?                    @map("meeting_minutes")
  nextReviewDate DateTime?                  @map("next_review_date")
  organizationId String                     @map("organization_id")
  facilitatorId  String                     @map("facilitator_id")
  createdById    String                     @map("created_by_id")
  createdAt      DateTime                   @default(now()) @map("created_at")
  updatedAt      DateTime                   @updatedAt @map("updated_at")

  organization Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  facilitator  User                        @relation("ReviewFacilitator", fields: [facilitatorId], references: [id])
  createdBy    User                        @relation("ReviewCreator", fields: [createdById], references: [id])
  standards    ManagementReviewStandard[]
  attendees    ManagementReviewAttendee[]
  agendaItems  ManagementReviewAgendaItem[]
  actions      ManagementReviewAction[]

  @@index([organizationId, reviewDate(sort: Desc)], map: "idx_mgmt_review_org_date")
  @@index([organizationId, status], map: "idx_mgmt_review_org_status")
  @@map("management_reviews")
}

model ManagementReviewStandard {
  id         String   @id @default(uuid())
  reviewId   String   @map("review_id")
  standardId String   @map("standard_id")
  createdAt  DateTime @default(now()) @map("created_at")

  review   ManagementReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  standard Standard         @relation(fields: [standardId], references: [id])

  @@unique([reviewId, standardId])
  @@map("management_review_standards")
}

model ManagementReviewAttendee {
  id        String   @id @default(uuid())
  reviewId  String   @map("review_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  review ManagementReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User             @relation(fields: [userId], references: [id])

  @@unique([reviewId, userId])
  @@map("management_review_attendees")
}

model ManagementReviewAgendaItem {
  id        String         @id @default(uuid())
  reviewId  String         @map("review_id")
  type      AgendaItemType
  title     String
  notes     String?
  sortOrder Int            @map("sort_order")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  review ManagementReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("management_review_agenda_items")
}

model ManagementReviewAction {
  id          String             @id @default(uuid())
  reviewId    String             @map("review_id")
  description String
  status      ReviewActionStatus @default(OPEN)
  dueDate     DateTime?          @map("due_date")
  completedAt DateTime?          @map("completed_at")
  assigneeId  String?            @map("assignee_id")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  review   ManagementReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  assignee User?            @relation(fields: [assigneeId], references: [id])

  @@index([reviewId, status], map: "idx_review_action_status")
  @@map("management_review_actions")
}

// ─────────────────────────────────────────────
// PARTNER PROGRAM
// ─────────────────────────────────────────────

model Partner {
  id                  String        @id @default(uuid())
  name                String                             // Partner company name
  slug                String        @unique              // URL-safe identifier
  tier                PartnerTier
  status              PartnerStatus @default(APPLIED)
  contactEmail        String        @map("contact_email")
  contactPhone        String?       @map("contact_phone")
  website             String?
  registrationNumber  String?       @map("registration_number") // SA CIPC number
  description         String?       @db.Text

  // Pricing (negotiable per partner — these are defaults for new client orgs)
  basePlatformFeeCents    Int       @map("base_platform_fee_cents")   // Monthly platform fee in cents
  defaultSmallFeeCents    Int       @default(149900) @map("default_small_fee_cents")   // R1,499 Essentials
  defaultMediumFeeCents   Int       @default(199900) @map("default_medium_fee_cents")  // R1,999 Professional
  defaultLargeFeeCents    Int       @default(299900) @map("default_large_fee_cents")   // R2,999 Business
  volumeDiscountPercent   Float     @default(0) @map("volume_discount_percent")        // Negotiated volume discount
  commissionPercent       Float     @default(10) @map("commission_percent")            // Referral commission %

  // Bank details (for commission payouts — REFERRAL partners)
  bankName            String?   @map("bank_name")
  bankAccountHolder   String?   @map("bank_account_holder")
  bankAccountNumber   String?   @map("bank_account_number")
  bankBranchCode      String?   @map("bank_branch_code")
  bankAccountType     String?   @map("bank_account_type")     // CHEQUE or SAVINGS

  // Branding (WHITE_LABEL partners)
  logoKey             String?   @map("logo_key")              // R2 key for partner logo
  primaryColor        String?   @map("primary_color")         // Hex color e.g. #1e40af
  accentColor         String?   @map("accent_color")          // Hex color e.g. #3b82f6
  brandName           String?   @map("brand_name")            // Display name override

  // Operational
  maxClientOrgs       Int?          @map("max_client_orgs")          // null = unlimited
  approvedAt          DateTime?     @map("approved_at")
  terminatedAt        DateTime?     @map("terminated_at")
  notes               String?       @db.Text                         // Internal admin notes
  accessToken         String?       @unique @map("access_token")      // Token-based dashboard access for referral partners
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  // Relations
  partnerUsers        PartnerUser[]
  clientOrganizations PartnerOrganization[]
  invoices            PartnerInvoice[]
  referrals           Referral[]
  auditScores         PartnerAuditScore[]
  alerts              PartnerAlert[]

  @@index([status], map: "idx_partner_status")
  @@index([tier], map: "idx_partner_tier")
  @@map("partners")
}

model PartnerUser {
  id          String      @id @default(uuid())
  partnerId   String      @map("partner_id")
  userId      String      @map("user_id")
  role        PartnerRole @default(PARTNER_MANAGER)
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([partnerId, userId])
  @@index([userId], map: "idx_partner_user_user")
  @@map("partner_users")
}

model PartnerOrganization {
  id                String           @id @default(uuid())
  partnerId         String           @map("partner_id")
  organizationId    String           @map("organization_id")
  clientSize        PartnerClientSize @default(SMALL) @map("client_size")
  isActive          Boolean          @default(true) @map("is_active")

  // Per-client fee override (null = use partner default for this size)
  customFeeCents    Int?             @map("custom_fee_cents")

  // Metadata
  onboardedAt       DateTime         @default(now()) @map("onboarded_at")
  disconnectedAt    DateTime?        @map("disconnected_at")
  notes             String?          @db.Text
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  partner      Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([partnerId, organizationId])
  @@index([organizationId], map: "idx_partner_org_org")
  @@map("partner_organizations")
}

model PartnerInvoice {
  id                  String        @id @default(uuid())
  partnerId           String        @map("partner_id")
  invoiceNumber       String        @unique @map("invoice_number")
  status              InvoiceStatus @default(DRAFT)

  // Amounts in cents (ZAR)
  platformFeeCents    Int           @map("platform_fee_cents")
  clientFeesCents     Int           @map("client_fees_cents")     // Sum of all per-client fees
  discountCents       Int           @default(0) @map("discount_cents") // Volume discount
  subtotalCents       Int           @map("subtotal_cents")
  vatCents            Int           @map("vat_cents")             // 15% SA VAT
  totalCents          Int           @map("total_cents")

  // Period
  periodStart         DateTime      @map("period_start")
  periodEnd           DateTime      @map("period_end")
  dueAt               DateTime      @map("due_at")
  paidAt              DateTime?     @map("paid_at")

  // Line items breakdown (JSON array)
  lineItems           Json          @map("line_items")

  // Payment
  externalPaymentId   String?       @map("external_payment_id")
  notes               String?       @db.Text

  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, createdAt(sort: Desc)], map: "idx_partner_invoice_partner")
  @@index([status], map: "idx_partner_invoice_status")
  @@map("partner_invoices")
}

// ─────────────────────────────────────────────
// REFERRAL PROGRAM
// ─────────────────────────────────────────────

enum ReferralStatus {
  PENDING       // Link generated, no signup yet
  CLICKED       // Link was visited
  SIGNED_UP     // Org created but not paid
  CONVERTED     // Org became a paid customer
  EXPIRED       // Link expired without conversion
  CANCELLED     // Manually cancelled
}

model Referral {
  id                String         @id @default(uuid())
  partnerId         String         @map("partner_id")
  code              String         @unique                    // e.g. "acme-x7k2m9"

  // Tracking
  referredOrgId     String?        @map("referred_org_id")
  status            ReferralStatus @default(PENDING)

  // Contact info captured at signup
  referredEmail     String?        @map("referred_email")
  referredCompany   String?        @map("referred_company")

  // Conversion tracking
  clickCount        Int            @default(0) @map("click_count")
  signedUpAt        DateTime?      @map("signed_up_at")
  convertedAt       DateTime?      @map("converted_at")

  // Commission (10% of Year 1, accrued monthly over 12 payments)
  commissionPercent     Float          @map("commission_percent")       // Snapshot from partner at creation
  commissionCents       Int?           @map("commission_cents")         // Total commission earned so far (accrued)
  commissionMonthsEarned Int          @default(0) @map("commission_months_earned") // How many months credited (max 12)
  commissionPaidAt      DateTime?      @map("commission_paid_at")

  expiresAt         DateTime       @map("expires_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  partner      Partner       @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  referredOrg  Organization? @relation(fields: [referredOrgId], references: [id], onDelete: SetNull)

  @@index([partnerId, status], map: "idx_referral_partner_status")
  @@map("referrals")
}

// ─────────────────────────────────────────────
// PARTNER AUDIT & COMPLIANCE
// ─────────────────────────────────────────────

enum PartnerRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PartnerAlertType {
  LOW_USER_ACTIVITY
  GHOST_SEATS
  USER_SPIKE
  CLIENT_DENSITY_HIGH
  INACTIVE_CLIENT
  REVENUE_DECLINE
  OVERDUE_INVOICE
  CLIENT_CHURN
  TERMS_EXPIRY
  COMPLIANCE_GAP
  STATUS_CHANGE
  BRANDING_CHANGE
  MAX_CLIENTS_REACHED
}

enum PartnerAlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

model PartnerAuditScore {
  id                     String           @id @default(uuid())
  partnerId              String           @map("partner_id")
  periodMonth            String           @map("period_month") // "YYYY-MM" e.g. "2026-03"

  // User metrics
  totalUsers             Int              @default(0) @map("total_users")
  activeUsers            Int              @default(0) @map("active_users")
  activityScore          Int              @default(0) @map("activity_score") // 0-100

  // Client density
  totalClientOrgs        Int              @default(0) @map("total_client_orgs")
  avgUsersPerClient      Float            @default(0) @map("avg_users_per_client")
  clientDensityScore     Int              @default(0) @map("client_density_score") // 0-100

  // Revenue
  totalRevenueCents      Int              @default(0) @map("total_revenue_cents")
  revenueGrowthPercent   Float            @default(0) @map("revenue_growth_percent")
  revenueScore           Int              @default(0) @map("revenue_score") // 0-100

  // Feature utilization
  featureUtilizationScore Int             @default(0) @map("feature_utilization_score") // 0-100

  // Composite
  overallScore           Int              @default(0) @map("overall_score") // 0-100
  riskLevel              PartnerRiskLevel @default(LOW) @map("risk_level")

  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, periodMonth], map: "uq_partner_audit_score_period")
  @@index([partnerId, createdAt(sort: Desc)], map: "idx_partner_audit_score_partner")
  @@index([riskLevel], map: "idx_partner_audit_score_risk")
  @@map("partner_audit_scores")
}

model PartnerAlert {
  id           String             @id @default(uuid())
  partnerId    String             @map("partner_id")
  alertType    PartnerAlertType   @map("alert_type")
  severity     PartnerRiskLevel
  title        String
  description  String?            @db.Text
  metadata     Json?              // Supporting data (user counts, percentages, etc.)
  status       PartnerAlertStatus @default(OPEN)
  resolvedAt   DateTime?          @map("resolved_at")
  resolvedById String?            @map("resolved_by_id")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  partner    Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  resolvedBy User?   @relation("PartnerAlertResolver", fields: [resolvedById], references: [id])

  @@index([partnerId, status, createdAt(sort: Desc)], map: "idx_partner_alert_partner_status")
  @@index([severity, status], map: "idx_partner_alert_severity")
  @@map("partner_alerts")
}

// ─────────────────────────────────────────────
// LEGAL — TERMS & AGREEMENTS
// ─────────────────────────────────────────────

model TermsVersion {
  id          String             @id @default(uuid())
  version     String             @unique              // e.g. "1.0", "1.1", "2.0"
  title       String                                  // e.g. "Terms of Service & Privacy Policy"
  content     String             @db.Text             // Full legal text (markdown)
  summary     String?            @db.Text             // Change summary for re-acceptance
  status      TermsVersionStatus @default(DRAFT)
  effectiveAt DateTime           @map("effective_at")
  publishedAt DateTime?          @map("published_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  acceptances TermsAcceptance[]

  @@index([status], map: "idx_terms_version_status")
  @@map("terms_versions")
}

model TermsAcceptance {
  id         String   @id @default(uuid())
  versionId  String   @map("version_id")
  userId     String   @map("user_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent") @db.Text
  acceptedAt DateTime @default(now()) @map("accepted_at")

  version TermsVersion @relation(fields: [versionId], references: [id])
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, versionId])
  @@index([userId, acceptedAt(sort: Desc)], map: "idx_terms_acceptance_user")
  @@index([versionId], map: "idx_terms_acceptance_version")
  @@map("terms_acceptances")
}

// ─────────────────────────────────────────────
// QUOTATIONS & PROFORMA INVOICES
// ─────────────────────────────────────────────

model Quotation {
  id               String          @id @default(uuid())
  quotationNumber  String          @unique @map("quotation_number")   // QT-YYYY-NNNN
  invoiceNumber    String?         @unique @map("invoice_number")     // INV-YYYY-NNNN (set on conversion)
  status           QuotationStatus @default(DRAFT)

  // Client details (not org-scoped — external clients)
  clientName       String          @map("client_name")
  clientCompany    String?         @map("client_company")
  clientEmail      String?         @map("client_email")
  clientPhone      String?         @map("client_phone")
  clientAddress    String?         @map("client_address") @db.Text
  clientVatNumber  String?         @map("client_vat_number")
  clientRegNumber  String?         @map("client_reg_number")

  // Amounts in cents
  subtotalCents    Int             @map("subtotal_cents")
  discountLabel    String?         @map("discount_label")              // e.g. "Annual upfront — 2 months free"
  discountCents    Int?            @map("discount_cents")              // Fixed ZAR discount in cents
  vatCents         Int             @map("vat_cents")
  totalCents       Int             @map("total_cents")
  depositPercent   Int?            @map("deposit_percent")            // e.g. 50
  depositCents     Int?            @map("deposit_cents")

  // Line items as JSON: { description, quantity, unitPriceCents, totalCents }[]
  lineItems        Json            @map("line_items")

  // Dates
  issuedAt         DateTime        @default(now()) @map("issued_at")
  validUntil       DateTime        @map("valid_until")
  sentAt           DateTime?       @map("sent_at")
  acceptedAt       DateTime?       @map("accepted_at")
  declinedAt       DateTime?       @map("declined_at")
  invoicedAt       DateTime?       @map("invoiced_at")
  paidAt           DateTime?       @map("paid_at")

  bankReference    String?         @map("bank_reference")
  notes            String?         @db.Text
  terms            String?         @db.Text

  createdById      String          @map("created_by_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  createdBy        User            @relation(fields: [createdById], references: [id])

  @@index([status], map: "idx_quotation_status")
  @@index([createdById], map: "idx_quotation_created_by")
  @@map("quotations")
}

// ─────────────────────────────────────────────
// EQUIPMENT / ASSET MANAGEMENT
// ─────────────────────────────────────────────

model Equipment {
  id               String          @id @default(uuid())
  assetNumber      String          @map("asset_number")
  name             String
  description      String?         @db.Text
  category         String
  manufacturer     String?
  model            String?
  serialNumber     String?         @map("serial_number")
  status           EquipmentStatus @default(ACTIVE)
  location         String?
  swl              String?                          // Safe Working Load (e.g. "5 tonnes")
  ceMarking        Boolean         @default(false)  @map("ce_marking")
  purchaseDate     DateTime?       @map("purchase_date")
  commissionDate   DateTime?       @map("commission_date")
  decommissionDate DateTime?       @map("decommission_date")
  warrantyExpiry   DateTime?       @map("warranty_expiry")
  specifications   Json?                            // Flexible key/value: proof load, legislation, exam interval
  notes            String?         @db.Text
  nextCalibrationDue DateTime?     @map("next_calibration_due")

  organizationId   String          @map("organization_id")
  projectId        String?         @map("project_id")
  siteId           String?         @map("site_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project?        @relation(fields: [projectId], references: [id])
  site             Site?           @relation(fields: [siteId], references: [id], onDelete: SetNull)

  calibrationRecords CalibrationRecord[]
  maintenanceRecords MaintenanceRecord[]
  repairRecords      RepairRecord[]

  @@unique([organizationId, assetNumber])
  @@index([organizationId, status], map: "idx_equipment_org_status")
  @@index([organizationId, category], map: "idx_equipment_org_category")
  @@index([organizationId, nextCalibrationDue], map: "idx_equipment_org_calibration_due")
  @@map("equipment")
}

model CalibrationRecord {
  id                String          @id @default(uuid())
  equipmentId       String          @map("equipment_id")
  calibrationDate   DateTime        @map("calibration_date")
  nextDueDate       DateTime        @map("next_due_date")
  certificateNumber String?         @map("certificate_number")
  certificateFileKey String?        @map("certificate_file_key")
  certificateFileName String?       @map("certificate_file_name")
  calibratedBy      String          @map("calibrated_by")
  result            CalibrationResult
  deviation         String?
  notes             String?         @db.Text

  organizationId    String          @map("organization_id")
  recordedById      String          @map("recorded_by_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  equipment         Equipment       @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  recordedBy        User            @relation("CalibrationRecorder", fields: [recordedById], references: [id])

  @@index([equipmentId, nextDueDate], map: "idx_calibration_equipment_due")
  @@index([organizationId, nextDueDate], map: "idx_calibration_org_due")
  @@map("calibration_records")
}

model MaintenanceRecord {
  id              String            @id @default(uuid())
  equipmentId     String            @map("equipment_id")
  scheduledDate   DateTime          @map("scheduled_date")
  completedDate   DateTime?         @map("completed_date")
  status          MaintenanceStatus @default(SCHEDULED)
  maintenanceType String            @map("maintenance_type")  // Routine, Preventive, Corrective, Overhaul
  description     String            @db.Text
  performedBy     String?           @map("performed_by")
  cost            Decimal?          @db.Decimal(12, 2)
  notes           String?           @db.Text

  organizationId  String            @map("organization_id")
  recordedById    String            @map("recorded_by_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  equipment       Equipment         @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  recordedBy      User              @relation("MaintenanceRecorder", fields: [recordedById], references: [id])

  @@index([equipmentId, scheduledDate], map: "idx_maintenance_equipment_date")
  @@index([organizationId, status, scheduledDate], map: "idx_maintenance_org_status_date")
  @@map("maintenance_records")
}

model RepairRecord {
  id                String         @id @default(uuid())
  equipmentId       String         @map("equipment_id")
  repairDate        DateTime       @map("repair_date")
  description       String         @db.Text
  supplierName      String         @map("supplier_name")
  supplierReference String?        @map("supplier_reference")
  priority          RepairPriority @default(MEDIUM)
  cost              Decimal?       @db.Decimal(12, 2)
  partsUsed         Json?          @map("parts_used")
  verificationDate  DateTime?      @map("verification_date")
  verifiedBy        String?        @map("verified_by")
  verificationNotes String?        @map("verification_notes") @db.Text
  returnToServiceDate DateTime?    @map("return_to_service_date")
  capaId            String?        @map("capa_id")

  organizationId    String         @map("organization_id")
  recordedById      String         @map("recorded_by_id")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  equipment         Equipment      @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  recordedBy        User           @relation("RepairRecorder", fields: [recordedById], references: [id])
  capa              Capa?          @relation(fields: [capaId], references: [id])

  @@index([equipmentId, repairDate], map: "idx_repair_equipment_date")
  @@index([organizationId, createdAt], map: "idx_repair_org_created")
  @@map("repair_records")
}

// ─────────────────────────────────────────────
// ENTERPRISE — REGULATORY COMPLIANCE & MONITORING
// ─────────────────────────────────────────────

model ClauseRegulatoryMetadata {
  id                     String   @id @default(uuid())
  standardClauseId       String   @unique @map("standard_clause_id")
  reportingDeadlineHours Int?     @map("reporting_deadline_hours")
  reportingAuthority     String?  @map("reporting_authority")
  penaltyDescription     String?  @map("penalty_description") @db.Text
  complianceFrequency    String?  @map("compliance_frequency")
  formReference          String?  @map("form_reference")
  isReportable           Boolean  @default(false) @map("is_reportable")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  standardClause StandardClause @relation(fields: [standardClauseId], references: [id], onDelete: Cascade)

  @@map("clause_regulatory_metadata")
}

model ComplianceObligation {
  id                String           @id @default(uuid())
  title             String
  obligationType    String           @map("obligation_type")
  standardClauseId  String?          @map("standard_clause_id")
  organizationId    String           @map("organization_id")
  vendorId          String?          @map("vendor_id")
  projectId         String?          @map("project_id")
  siteId            String?          @map("site_id")
  responsibleUserId String?          @map("responsible_user_id")
  status            ObligationStatus @default(PENDING)
  effectiveDate     DateTime?        @map("effective_date")
  expiryDate        DateTime?        @map("expiry_date")
  renewalLeadDays   Int?             @default(30) @map("renewal_lead_days")
  documentId        String?          @map("document_id")
  metadata          Json?
  lastReviewedAt    DateTime?        @map("last_reviewed_at")
  lastReviewedById  String?          @map("last_reviewed_by_id")
  notes             String?          @db.Text
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor          Vendor?         @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  project         Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  site            Site?           @relation(fields: [siteId], references: [id], onDelete: SetNull)
  standardClause  StandardClause? @relation(fields: [standardClauseId], references: [id], onDelete: SetNull)
  document        Document?       @relation(fields: [documentId], references: [id], onDelete: SetNull)
  responsibleUser User?           @relation("ObligationResponsible", fields: [responsibleUserId], references: [id])
  lastReviewedBy  User?           @relation("ObligationReviewer", fields: [lastReviewedById], references: [id])
  monitoringPoints MonitoringPoint[]

  @@index([organizationId, status], map: "idx_obligation_org_status")
  @@index([organizationId, expiryDate], map: "idx_obligation_org_expiry")
  @@index([vendorId], map: "idx_obligation_vendor")
  @@index([obligationType], map: "idx_obligation_type")
  @@map("compliance_obligations")
}

model MonitoringPoint {
  id               String   @id @default(uuid())
  name             String
  pointType        String   @map("point_type")
  location         String?
  description      String?  @db.Text
  organizationId   String   @map("organization_id")
  projectId        String?  @map("project_id")
  standardClauseId String?  @map("standard_clause_id")
  obligationId     String?  @map("obligation_id")
  isActive         Boolean  @default(true) @map("is_active")
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  standardClause StandardClause?       @relation(fields: [standardClauseId], references: [id], onDelete: SetNull)
  obligation     ComplianceObligation? @relation(fields: [obligationId], references: [id], onDelete: SetNull)
  objectives     Objective[]           @relation("MonitoringPointObjectives")

  @@index([organizationId, pointType], map: "idx_monitoring_org_type")
  @@map("monitoring_points")
}

// ─────────────────────────────────────────────
// TRAINING RECORDS
// ─────────────────────────────────────────────

model TrainingRecord {
  id                      String           @id @default(uuid())
  title                   String
  category                TrainingCategory
  status                  TrainingStatus   @default(PLANNED)
  description             String?          @db.Text
  trainingDate            DateTime         @map("training_date")
  duration                String?
  location                String?
  trainerName             String?          @map("trainer_name")
  trainerAccreditation    String?          @map("trainer_accreditation")
  trainingProvider        String?          @map("training_provider")
  providerAccreditationNo String?          @map("provider_accreditation_no")
  certificateNumber       String?          @map("certificate_number")
  certificateFileKey      String?          @map("certificate_file_key")
  certificateFileName     String?          @map("certificate_file_name")
  issuedDate              DateTime?        @map("issued_date")
  expiryDate              DateTime?        @map("expiry_date")
  assessmentResult        String?          @map("assessment_result")
  saqaUnitStandard        String?          @map("saqa_unit_standard")
  nqfLevel                Int?             @map("nqf_level")
  notes                   String?          @db.Text

  traineeId               String           @map("trainee_id")
  organizationId          String           @map("organization_id")
  siteId                  String?          @map("site_id")
  recordedById            String           @map("recorded_by_id")
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")

  // Relations
  trainee        User         @relation("Trainee", fields: [traineeId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  site           Site?        @relation(fields: [siteId], references: [id], onDelete: SetNull)
  recordedBy     User         @relation("TrainingRecorder", fields: [recordedById], references: [id])

  @@index([organizationId, traineeId], map: "idx_training_org_trainee")
  @@index([organizationId, category], map: "idx_training_org_category")
  @@index([organizationId, expiryDate], map: "idx_training_org_expiry")
  @@index([organizationId, status], map: "idx_training_org_status")
  @@map("training_records")
}
