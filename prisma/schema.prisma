// ConformEdge - Prisma Schema
// South African compliance & quality management platform

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  AUDITOR
  VIEWER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum DocumentStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  EXPIRED
  ARCHIVED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CAPAType {
  CORRECTIVE
  PREVENTIVE
}

enum CAPAStatus {
  OPEN
  IN_PROGRESS
  VERIFICATION
  CLOSED
  OVERDUE
}

enum CAPAPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ChecklistStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum VendorTier {
  PLATINUM
  GOLD
  SILVER
  BRONZE
  UNRATED
}

enum AuditPackStatus {
  DRAFT
  COMPILING
  READY
  SUBMITTED
  ACCEPTED
}

enum NotificationType {
  DOCUMENT_EXPIRY
  CAPA_DUE
  ASSESSMENT_SCHEDULED
  CERT_EXPIRY
  SYSTEM
  APPROVAL_REQUEST
  CERT_UPLOAD
  CHECKLIST_DUE
  INCIDENT_REPORTED
  OBJECTIVE_DUE
  MANAGEMENT_REVIEW_DUE
  PERMIT_EXPIRING
  INVESTIGATION_OVERDUE
  STATUTORY_DEADLINE
  CALIBRATION_DUE
  CALIBRATION_OVERDUE
  MAINTENANCE_DUE
  EQUIPMENT_QUARANTINED
  SUBSCRIPTION_TRIAL_ENDING
  SUBSCRIPTION_PAYMENT_FAILED
  SUBSCRIPTION_CANCELLED
  QUOTA_LIMIT_REACHED
  QUOTA_WARNING
  TEAM_INVITATION
  OBLIGATION_EXPIRING
  VENDOR_COMPLIANCE_ALERT
  TRAINING_EXPIRING
}

enum ApprovalStepStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

enum ApprovalRequestStatus {
  IN_PROGRESS
  APPROVED
  REJECTED
  CANCELLED
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum CrossReferenceType {
  EQUIVALENT
  RELATED
  SUPPORTING
}

enum ShareLinkType {
  DOCUMENT
  AUDIT_PACK
  PORTAL
  VENDOR @map("SUBCONTRACTOR")
}

enum CertificationStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum RecurrenceFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
  CUSTOM
}

enum ShareLinkStatus {
  ACTIVE
  EXPIRED
  REVOKED
}


enum ManagementReviewStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AgendaItemType {
  AUDIT_RESULTS
  CUSTOMER_FEEDBACK
  PROCESS_PERFORMANCE
  CAPA_STATUS
  PREVIOUS_ACTIONS
  CHANGES_CONTEXT
  IMPROVEMENT_OPPORTUNITIES
  RESOURCE_NEEDS
  RISK_OPPORTUNITIES
  OBJECTIVES_PERFORMANCE
  INCIDENT_TRENDS
  OTHER
}

enum ReviewActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ObjectiveStatus {
  DRAFT
  ACTIVE
  ON_TRACK
  AT_RISK
  BEHIND
  ACHIEVED
  CANCELLED
}

enum MeasurementFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum IncidentStatus {
  REPORTED
  INVESTIGATING
  CORRECTIVE_ACTION
  CLOSED
}

enum IncidentType {
  NEAR_MISS
  FIRST_AID
  MEDICAL
  LOST_TIME
  FATALITY
  ENVIRONMENTAL
  PROPERTY_DAMAGE
}

enum WorkPermitType {
  HOT_WORK
  CONFINED_SPACE
  WORKING_AT_HEIGHTS
  ELECTRICAL
  EXCAVATION
  LIFTING
  GENERAL
}

enum WorkPermitStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  SUSPENDED
  CLOSED
  CANCELLED
  EXPIRED
}

enum ExtensionStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────
// BILLING ENUMS
// ─────────────────────────────────────────────

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum PlanTier {
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

enum CreditTransactionType {
  PURCHASE
  USAGE
  ADJUSTMENT
  REFUND
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum PaymentMethod {
  PAYSTACK    // Card via Paystack (default, existing)
  EFT         // Manual bank transfer — admin marks paid
  INVOICE     // Net-30/60 terms — auto-generated invoices
  PREPAID     // Pre-funded account balance
}

enum AccountTransactionType {
  FUND        // Money deposited (EFT/card top-up)
  DEDUCT      // Auto-deducted for invoice payment
  REFUND      // Partial/full refund
  ADJUSTMENT  // Admin manual adjustment
}

// ─────────────────────────────────────────────
// PARTNER ENUMS
// ─────────────────────────────────────────────

enum PartnerTier {
  CONSULTING
  WHITE_LABEL
  REFERRAL
}

enum PartnerStatus {
  APPLIED
  APPROVED
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum PartnerRole {
  PARTNER_ADMIN     // Can manage partner settings, users, all client orgs
  PARTNER_MANAGER   // Can view/edit assigned client orgs
  PARTNER_VIEWER    // Read-only across assigned client orgs
}

enum PartnerClientSize {
  SMALL             // ≤5 users, ≤2 standards — R1,299/mo default
  MEDIUM            // 6-15 users, 3-5 standards — R1,899/mo default
  LARGE             // 16+ users, all standards — R2,499/mo default
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
  INVOICED
}

enum TermsVersionStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
}

// ─────────────────────────────────────────────
// EQUIPMENT ENUMS
// ─────────────────────────────────────────────

enum EquipmentStatus {
  ACTIVE
  INACTIVE
  UNDER_REPAIR
  DECOMMISSIONED
  QUARANTINED
}

enum CalibrationResult {
  PASS
  FAIL
  CONDITIONAL
}

enum MaintenanceStatus {
  SCHEDULED
  COMPLETE
  POSTPONED
  CANCELLED
}

enum RepairPriority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

// ─────────────────────────────────────────────
// ENTERPRISE ENUMS
// ─────────────────────────────────────────────

enum StandardType {
  MANAGEMENT_SYSTEM
  STATUTORY
  PROFESSIONAL_BODY
}

enum OrganizationType {
  STANDALONE
  CORPORATE
  DIVISION
  SITE
}

enum SiteType {
  HEADQUARTERS
  DIVISION
  REGIONAL_OFFICE
  SITE
  PLANT
  DEPOT
  WAREHOUSE
}

enum ObligationStatus {
  PENDING
  ACTIVE
  EXPIRED
  REVOKED
  NOT_APPLICABLE
}

enum TrainingStatus {
  PLANNED
  COMPLETED
  EXPIRED
  REVOKED
}

enum TrainingCategory {
  INDUCTION
  FIRST_AID
  FIRE_FIGHTING
  WORKING_AT_HEIGHTS
  SCAFFOLDING
  CRANE_OPERATOR
  FORKLIFT_OPERATOR
  CONFINED_SPACE
  HAZARDOUS_CHEMICALS
  ELECTRICAL
  EXCAVATION
  H_AND_S_REPRESENTATIVE
  TOOLBOX_TALK
  COMPETENCY
  REFRESHER
  OTHER
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model Organization {
  id                     String           @id @default(uuid())
  clerkOrgId             String           @unique @map("clerk_org_id")
  name                   String
  slug                   String           @unique
  industry               String?
  country                String           @default("ZA")
  settings               Json?
  parentOrganizationId   String?          @map("parent_organization_id")
  organizationType       OrganizationType @default(STANDALONE) @map("organization_type")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")

  // Hierarchy
  parentOrganization Organization?  @relation("OrgHierarchy", fields: [parentOrganizationId], references: [id])
  childOrganizations Organization[] @relation("OrgHierarchy")

  // Relations
  members          OrganizationUser[]
  projects         Project[]
  documents        Document[]
  assessments      Assessment[]
  capas            Capa[]
  checklists       ComplianceChecklist[]
  vendors          Vendor[]
  auditPacks       AuditPack[]
  auditTrailEvents AuditTrailEvent[]
  notifications              Notification[]
  checklistTemplates         ChecklistTemplate[]
  approvalWorkflowTemplates  ApprovalWorkflowTemplate[]
  approvalRequests           ApprovalRequest[]
  shareLinks                 ShareLink[]

  incidents                  Incident[]
  objectives                 Objective[]
  managementReviews          ManagementReview[]
  workPermits                WorkPermit[]
  organizationStandards      OrganizationStandard[]
  partnerOrganizations       PartnerOrganization[]
  referrals                  Referral[]
  equipment                  Equipment[]

  // Enterprise — compliance obligations, monitoring, sites
  complianceObligations ComplianceObligation[]
  monitoringPoints      MonitoringPoint[]
  sites                 Site[]
  trainingRecords       TrainingRecord[]

  // Billing
  subscription        Subscription?
  creditBalance       CreditBalance?
  invoices            Invoice[]
  creditTransactions  CreditTransaction[]
  usageRecords        UsageRecord[]
  accountBalance      AccountBalance?
  accountTransactions AccountTransaction[]

  @@index([parentOrganizationId], map: "idx_org_parent")
  @@map("organizations")
}

model User {
  id          String    @id @default(uuid())
  clerkUserId String    @unique @map("clerk_user_id")
  email       String    @unique
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  imageUrl    String?   @map("image_url")
  isSuperAdmin Boolean   @default(false) @map("is_super_admin")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  memberships             OrganizationUser[]
  uploadedDocuments       Document[]               @relation("DocumentUploader")
  verifiedClassifications DocumentClassification[]  @relation("ClassificationVerifier")
  conductedAssessments    Assessment[]              @relation("Assessor")
  assessmentAnswers       AssessmentAnswer[]
  raisedCapas             Capa[]                    @relation("CapaRaiser")
  assignedCapas           Capa[]                    @relation("CapaAssignee")
  assignedCapaActions     CapaAction[]
  assignedChecklists      ComplianceChecklist[]
  createdAuditPacks       AuditPack[]
  auditTrailEvents        AuditTrailEvent[]
  notifications              Notification[]
  notificationPreferences    NotificationPreference[]
  checklistTemplates         ChecklistTemplate[]
  submittedApprovalRequests  ApprovalRequest[]          @relation("ApprovalSubmitter")
  assignedApprovalSteps      ApprovalStep[]             @relation("ApprovalStepAssignee")
  createdWorkflowTemplates   ApprovalWorkflowTemplate[] @relation("WorkflowTemplateCreator")
  createdShareLinks          ShareLink[]                @relation("ShareLinkCreator")
  defaultAssigneeTemplates   ChecklistTemplate[]        @relation("TemplateDefaultAssignee")

  reportedIncidents          Incident[]                 @relation("IncidentReporter")
  investigatedIncidents      Incident[]                 @relation("IncidentInvestigator")
  signedOffIncidents         Incident[]                 @relation("IncidentSignOff")
  uploadedEvidence           IncidentEvidence[]         @relation("EvidenceUploader")
  ownedObjectives            Objective[]                @relation("ObjectiveOwner")
  recordedMeasurements       ObjectiveMeasurement[]     @relation("MeasurementRecorder")
  facilitatedReviews         ManagementReview[]         @relation("ReviewFacilitator")
  createdReviews             ManagementReview[]         @relation("ReviewCreator")
  reviewAttendances          ManagementReviewAttendee[]
  reviewActions              ManagementReviewAction[]
  requestedPermits           WorkPermit[]              @relation("PermitRequester")
  issuedPermits              WorkPermit[]              @relation("PermitIssuer")
  checkedPermitItems         WorkPermitChecklist[]     @relation("PermitChecklistChecker")
  reviewedExtensions         WorkPermitExtension[]     @relation("ExtensionReviewer")
  requestedExtensions        WorkPermitExtension[]     @relation("ExtensionRequester")
  partnerUsers               PartnerUser[]
  resolvedPartnerAlerts      PartnerAlert[]            @relation("PartnerAlertResolver")
  termsAcceptances           TermsAcceptance[]
  quotations                 Quotation[]
  recordedCalibrations       CalibrationRecord[]      @relation("CalibrationRecorder")
  recordedMaintenance        MaintenanceRecord[]      @relation("MaintenanceRecorder")
  recordedRepairs            RepairRecord[]           @relation("RepairRecorder")
  responsibleObligations     ComplianceObligation[]   @relation("ObligationResponsible")
  reviewedObligations        ComplianceObligation[]   @relation("ObligationReviewer")
  managedSites               Site[]                   @relation("SiteManager")
  trainingCompleted          TrainingRecord[]         @relation("Trainee")
  trainingRecorded           TrainingRecord[]         @relation("TrainingRecorder")

  @@map("users")
}

model OrganizationUser {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  organizationId String       @map("organization_id")
  role           UserRole     @default(VIEWER)
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("organization_users")
}

model Site {
  id             String    @id @default(uuid())
  name           String
  code           String
  siteType       SiteType  @default(SITE) @map("site_type")
  address        String?
  parentSiteId   String?   @map("parent_site_id")
  organizationId String    @map("organization_id")
  managerId      String?   @map("manager_id")
  isActive       Boolean   @default(true) @map("is_active")
  metadata       Json?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Hierarchy
  parentSite     Site?     @relation("SiteHierarchy", fields: [parentSiteId], references: [id])
  childSites     Site[]    @relation("SiteHierarchy")

  // Relations
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  manager        User?        @relation("SiteManager", fields: [managerId], references: [id])

  // Module relations
  projects              Project[]
  incidents             Incident[]
  workPermits           WorkPermit[]
  equipment             Equipment[]
  complianceObligations ComplianceObligation[]
  trainingRecords       TrainingRecord[]

  @@unique([organizationId, code])
  @@index([parentSiteId], map: "idx_site_parent")
  @@index([organizationId, isActive], map: "idx_site_org_active")
  @@map("sites")
}

model Project {
  id             String        @id @default(uuid())
  name           String
  description    String?
  status         ProjectStatus @default(PLANNING)
  startDate      DateTime?     @map("start_date")
  endDate        DateTime?     @map("end_date")
  organizationId String        @map("organization_id")
  siteId         String?       @map("site_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // Relations
  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  site               Site?                 @relation(fields: [siteId], references: [id], onDelete: SetNull)
  documents          Document[]
  assessments        Assessment[]
  capas              Capa[]
  checklists         ComplianceChecklist[]
  auditPacks         AuditPack[]
  checklistTemplates ChecklistTemplate[]   @relation("TemplateDefaultProject")
  incidents             Incident[]
  workPermits           WorkPermit[]
  equipment             Equipment[]
  complianceObligations ComplianceObligation[]
  monitoringPoints      MonitoringPoint[]

  @@map("projects")
}

model Standard {
  id           String       @id @default(uuid())
  code         String       @unique
  name         String
  version      String?
  description  String?
  standardType StandardType @default(MANAGEMENT_SYSTEM) @map("standard_type")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  // Relations
  clauses     StandardClause[]
  assessments Assessment[]
  checklists  ComplianceChecklist[]
  templates          ChecklistTemplate[]
  objectives         Objective[]
  managementReviews  ManagementReviewStandard[]
  organizationStandards OrganizationStandard[]

  @@map("standards")
}

model OrganizationStandard {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  standardId     String   @map("standard_id")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  standard     Standard     @relation(fields: [standardId], references: [id], onDelete: Cascade)

  @@unique([organizationId, standardId])
  @@map("organization_standards")
}

model StandardClause {
  id           String   @id @default(uuid())
  clauseNumber String   @map("clause_number")
  title        String
  description  String?
  parentId     String?  @map("parent_id")
  standardId   String   @map("standard_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  standard                 Standard                 @relation(fields: [standardId], references: [id], onDelete: Cascade)
  parent                   StandardClause?          @relation("ClauseHierarchy", fields: [parentId], references: [id])
  children                 StandardClause[]         @relation("ClauseHierarchy")
  classifications          DocumentClassification[]
  checklistItems           ChecklistItem[]
  crossReferencesAsSource  ClauseCrossReference[]   @relation("CrossRefSource")
  crossReferencesAsTarget  ClauseCrossReference[]   @relation("CrossRefTarget")
  capas                    CapaStandardClause[]
  objectives               Objective[]
  regulatoryMetadata       ClauseRegulatoryMetadata?
  complianceObligations    ComplianceObligation[]
  monitoringPoints         MonitoringPoint[]

  @@map("standard_clauses")
}

model Document {
  id               String         @id @default(uuid())
  title            String
  description      String?
  fileUrl          String?        @map("file_url")
  fileType         String?        @map("file_type")
  fileSize         Int?           @map("file_size")
  status           DocumentStatus @default(DRAFT)
  version          Int            @default(1)
  parentDocumentId String?        @map("parent_document_id")
  expiresAt        DateTime?      @map("expires_at")
  organizationId   String         @map("organization_id")
  projectId        String?        @map("project_id")
  uploadedById     String         @map("uploaded_by_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  // Relations
  organization    Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)
  uploadedBy      User                     @relation("DocumentUploader", fields: [uploadedById], references: [id])
  parentDocument  Document?                @relation("DocumentVersions", fields: [parentDocumentId], references: [id], onDelete: SetNull)
  childVersions         Document[]               @relation("DocumentVersions")
  classifications       DocumentClassification[]
  approvalRequests      ApprovalRequest[]
  complianceObligations ComplianceObligation[]

  @@index([organizationId, createdAt(sort: Desc)], map: "idx_document_org_created")
  @@index([organizationId, status], map: "idx_document_org_status")
  @@index([projectId], map: "idx_document_project")
  @@index([expiresAt], map: "idx_document_expires_at")
  @@map("documents")
}

model DocumentClassification {
  id               String    @id @default(uuid())
  documentId       String    @map("document_id")
  standardClauseId String    @map("standard_clause_id")
  confidence       Float
  isVerified       Boolean   @default(false) @map("is_verified")
  verifiedById     String?   @map("verified_by_id")
  verifiedAt       DateTime? @map("verified_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  document       Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  standardClause StandardClause @relation(fields: [standardClauseId], references: [id], onDelete: Cascade)
  verifiedBy     User?          @relation("ClassificationVerifier", fields: [verifiedById], references: [id])

  @@map("document_classifications")
}

model Assessment {
  id             String     @id @default(uuid())
  title          String
  description    String?
  scheduledDate  DateTime?  @map("scheduled_date")
  completedDate  DateTime?  @map("completed_date")
  overallScore   Float?     @map("overall_score")
  riskLevel      RiskLevel? @map("risk_level")
  organizationId String     @map("organization_id")
  projectId      String?    @map("project_id")
  assessorId     String     @map("assessor_id")
  standardId     String     @map("standard_id")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  // Relations
  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assessor     User                 @relation("Assessor", fields: [assessorId], references: [id])
  standard     Standard             @relation(fields: [standardId], references: [id])
  questions    AssessmentQuestion[]

  @@index([organizationId, createdAt(sort: Desc)], map: "idx_assessment_org_created")
  @@index([projectId], map: "idx_assessment_project")
  @@map("assessments")
}

model AssessmentQuestion {
  id           String   @id @default(uuid())
  question     String
  guidance     String?
  sortOrder    Int      @map("sort_order")
  assessmentId String   @map("assessment_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  assessment Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answers    AssessmentAnswer[]

  @@map("assessment_questions")
}

model AssessmentAnswer {
  id           String   @id @default(uuid())
  answer       String?
  score        Float?
  evidence     String?
  notes        String?
  questionId   String   @map("question_id")
  answeredById String   @map("answered_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  question   AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answeredBy User               @relation(fields: [answeredById], references: [id])

  @@map("assessment_answers")
}

model Capa {
  id             String       @id @default(uuid())
  title          String
  description    String?
  type           CAPAType
  status         CAPAStatus   @default(OPEN)
  priority       CAPAPriority @default(MEDIUM)
  rootCause      String?      @map("root_cause")
  rootCauseData  Json?        @map("root_cause_data")
  dueDate        DateTime?    @map("due_date")
  closedDate     DateTime?    @map("closed_date")
  organizationId String       @map("organization_id")
  projectId      String?      @map("project_id")
  raisedById     String       @map("raised_by_id")
  assignedToId   String?      @map("assigned_to_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  raisedBy     User         @relation("CapaRaiser", fields: [raisedById], references: [id])
  assignedTo   User?        @relation("CapaAssignee", fields: [assignedToId], references: [id])
  capaActions      CapaAction[]
  linkedItems      ChecklistItem[]
  standardClauses  CapaStandardClause[]
  incidents        Incident[]
  incidentCapas    IncidentCapa[]
  repairRecords    RepairRecord[]

  @@index([organizationId, createdAt(sort: Desc)], map: "idx_capa_org_created")
  @@index([organizationId, status], map: "idx_capa_org_status")
  @@index([projectId], map: "idx_capa_project")
  @@map("capas")
}

model CapaAction {
  id            String    @id @default(uuid())
  description   String
  dueDate       DateTime? @map("due_date")
  completedDate DateTime? @map("completed_date")
  isCompleted   Boolean   @default(false) @map("is_completed")
  capaId        String    @map("capa_id")
  assignedToId  String?   @map("assigned_to_id")
